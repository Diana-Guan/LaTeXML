  <para xml:id="p1" fragid="p1">
    <equation xml:id="S0.Ex1" fragid="S0.Ex1">
      <Math mode="display" tex="x+1" text="x + 1" xml:id="S0.Ex1.m1" fragid="S0.Ex1.m1"><m:math alttext="x+1" display="block"><m:semantics><m:apply><m:plus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
            <XMTok meaning="1" role="NUMBER">1</XMTok>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p2" fragid="p2">
    <equation xml:id="S0.Ex2" fragid="S0.Ex2">
      <Math mode="display" tex="x^{2}+1" text="x ^ 2 + 1" xml:id="S0.Ex2.m1" fragid="S0.Ex2.m1"><m:math alttext="x^{2}+1" display="block"><m:semantics><m:apply><m:plus/><m:apply><m:csymbol cd="ambiguous">superscript</m:csymbol><m:ci>𝑥</m:ci><m:cn type="integer">2</m:cn></m:apply><m:cn type="integer">1</m:cn></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMApp>
              <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
            </XMApp>
            <XMTok meaning="1" role="NUMBER">1</XMTok>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p3" fragid="p3">
    <equation xml:id="S0.Ex3" fragid="S0.Ex3">
      <Math mode="display" tex="x^{3}-4x+7" text="(x ^ 3 - 4 * x) + 7" xml:id="S0.Ex3.m1" fragid="S0.Ex3.m1"><m:math alttext="x^{3}-4x+7" display="block"><m:semantics><m:apply><m:plus/><m:apply><m:minus/><m:apply><m:csymbol cd="ambiguous">superscript</m:csymbol><m:ci>𝑥</m:ci><m:cn type="integer">3</m:cn></m:apply><m:apply><m:times/><m:cn type="integer">4</m:cn><m:ci>𝑥</m:ci></m:apply></m:apply><m:cn type="integer">7</m:cn></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMApp>
              <XMTok meaning="minus" role="ADDOP">-</XMTok>
              <XMApp>
                <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
                <XMTok fontsize="70%" meaning="3" role="NUMBER">3</XMTok>
              </XMApp>
              <XMApp>
                <XMTok meaning="times" role="MULOP">⁢</XMTok>
                <XMTok meaning="4" role="NUMBER">4</XMTok>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
              </XMApp>
            </XMApp>
            <XMTok meaning="7" role="NUMBER">7</XMTok>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p4" fragid="p4">
    <equation xml:id="S0.Ex4" fragid="S0.Ex4">
      <Math mode="display" tex="a+b+c" text="a + b + c" xml:id="S0.Ex4.m1" fragid="S0.Ex4.m1"><m:math alttext="a+b+c" display="block"><m:semantics><m:apply><m:plus/><m:ci>𝑎</m:ci><m:ci>𝑏</m:ci><m:ci>𝑐</m:ci></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMTok font="italic" role="UNKNOWN">a</XMTok>
            <XMTok font="italic" role="UNKNOWN">b</XMTok>
            <XMTok font="italic" role="UNKNOWN">c</XMTok>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p5" fragid="p5">
    <equation xml:id="S0.Ex5" fragid="S0.Ex5">
      <Math mode="display" tex="xy" text="x * y" xml:id="S0.Ex5.m1" fragid="S0.Ex5.m1"><m:math alttext="xy" display="block"><m:semantics><m:apply><m:times/><m:ci>𝑥</m:ci><m:ci>𝑦</m:ci></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="times" role="MULOP">⁢</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
            <XMTok font="italic" role="UNKNOWN">y</XMTok>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p6" fragid="p6">
    <equation xml:id="S0.Ex6" fragid="S0.Ex6">
      <Math mode="display" tex="x(y+1)" text="x * (y + 1)" xml:id="S0.Ex6.m1" fragid="S0.Ex6.m1"><m:math alttext="x(y+1)" display="block"><m:semantics><m:apply><m:times/><m:ci>𝑥</m:ci><m:apply><m:plus/><m:ci>𝑦</m:ci><m:cn type="integer">1</m:cn></m:apply></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="times" role="MULOP">⁢</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
            <XMDual>
              <XMRef idref="S0.Ex6.m1.1.xm"/>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMApp xml:id="S0.Ex6.m1.1.xm" fragid="S0.Ex6.m1.1.xm">
                  <XMTok meaning="plus" role="ADDOP">+</XMTok>
                  <XMTok font="italic" role="UNKNOWN">y</XMTok>
                  <XMTok meaning="1" role="NUMBER">1</XMTok>
                </XMApp>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMDual>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p7" fragid="p7">
    <equation xml:id="S0.Ex7" fragid="S0.Ex7">
      <Math mode="display" tex="\frac{x+1}{x-1}" text="(x + 1) / (x - 1)" xml:id="S0.Ex7.m1" fragid="S0.Ex7.m1"><m:math alttext="\frac{x+1}{x-1}" display="block"><m:semantics><m:apply><m:divide/><m:apply><m:plus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply><m:apply><m:minus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok mathstyle="display" meaning="divide" role="FRACOP"/>
            <XMApp>
              <XMTok meaning="plus" role="ADDOP">+</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
            <XMApp>
              <XMTok meaning="minus" role="ADDOP">-</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p8" fragid="p8">
    <equation xml:id="S0.Ex8" fragid="S0.Ex8">
      <Math mode="display" tex="\sqrt{x+1}" text="square-root@(x + 1)" xml:id="S0.Ex8.m1" fragid="S0.Ex8.m1"><m:math alttext="\sqrt{x+1}" display="block"><m:semantics><m:apply><m:root/><m:apply><m:plus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="square-root"/>
            <XMApp>
              <XMTok meaning="plus" role="ADDOP">+</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p9" fragid="p9">
    <equation xml:id="S0.Ex9" fragid="S0.Ex9">
      <Math mode="display" tex="\sqrt[3]{x}" text="nth-root@(3, x)" xml:id="S0.Ex9.m1" fragid="S0.Ex9.m1"><m:math alttext="\sqrt[3]{x}" display="block"><m:semantics><m:apply><m:root/><m:degree><m:cn type="integer">3</m:cn></m:degree><m:ci>𝑥</m:ci></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok meaning="nth-root"/>
            <XMTok fontsize="70%" meaning="3" role="NUMBER">3</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p10" fragid="p10">
    <equation xml:id="S0.Ex10" fragid="S0.Ex10">
      <Math mode="display" tex="(x+1)^{2}" text="(x + 1) ^ 2" xml:id="S0.Ex10.m1" fragid="S0.Ex10.m1"><m:math alttext="(x+1)^{2}" display="block"><m:semantics><m:apply><m:csymbol cd="ambiguous">superscript</m:csymbol><m:apply><m:plus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply><m:cn type="integer">2</m:cn></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
            <XMDual>
              <XMRef idref="S0.Ex10.m1.1.xm"/>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMApp xml:id="S0.Ex10.m1.1.xm" fragid="S0.Ex10.m1.1.xm">
                  <XMTok meaning="plus" role="ADDOP">+</XMTok>
                  <XMTok font="italic" role="UNKNOWN">x</XMTok>
                  <XMTok meaning="1" role="NUMBER">1</XMTok>
                </XMApp>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMDual>
            <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
