  <para xml:id="p1" fragid="p1">
    <equation xml:id="S0.Ex1" fragid="S0.Ex1">
      <Math mode="display" tex="\frac{1}{x^{2}-1}" text="1 / (x ^ 2 - 1)" xml:id="S0.Ex1.m1" fragid="S0.Ex1.m1"><m:math alttext="\frac{1}{x^{2}-1}" display="block"><m:semantics><m:apply><m:divide/><m:cn type="integer">1</m:cn><m:apply><m:minus/><m:apply><m:csymbol cd="ambiguous">superscript</m:csymbol><m:ci>𝑥</m:ci><m:cn type="integer">2</m:cn></m:apply><m:cn type="integer">1</m:cn></m:apply></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok mathstyle="display" meaning="divide" role="FRACOP"/>
            <XMTok meaning="1" role="NUMBER">1</XMTok>
            <XMApp>
              <XMTok meaning="minus" role="ADDOP">-</XMTok>
              <XMApp>
                <XMTok role="SUPERSCRIPTOP" scriptpos="post2"/>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
                <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
              </XMApp>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p2" fragid="p2">
    <equation xml:id="S0.Ex2" fragid="S0.Ex2">
      <Math mode="display" tex="\frac{1}{(x-1)(x+1)}" text="1 / ((x - 1) * (x + 1))" xml:id="S0.Ex2.m1" fragid="S0.Ex2.m1"><m:math alttext="\frac{1}{(x-1)(x+1)}" display="block"><m:semantics><m:apply><m:divide/><m:cn type="integer">1</m:cn><m:apply><m:times/><m:apply><m:minus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply><m:apply><m:plus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply></m:apply></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok mathstyle="display" meaning="divide" role="FRACOP"/>
            <XMTok meaning="1" role="NUMBER">1</XMTok>
            <XMApp>
              <XMTok meaning="times" role="MULOP">⁢</XMTok>
              <XMDual>
                <XMRef idref="S0.Ex2.m1.1.xm"/>
                <XMWrap>
                  <XMTok role="OPEN" stretchy="false">(</XMTok>
                  <XMApp xml:id="S0.Ex2.m1.1.xm" fragid="S0.Ex2.m1.1.xm">
                    <XMTok meaning="minus" role="ADDOP">-</XMTok>
                    <XMTok font="italic" role="UNKNOWN">x</XMTok>
                    <XMTok meaning="1" role="NUMBER">1</XMTok>
                  </XMApp>
                  <XMTok role="CLOSE" stretchy="false">)</XMTok>
                </XMWrap>
              </XMDual>
              <XMDual>
                <XMRef idref="S0.Ex2.m1.2.xm"/>
                <XMWrap>
                  <XMTok role="OPEN" stretchy="false">(</XMTok>
                  <XMApp xml:id="S0.Ex2.m1.2.xm" fragid="S0.Ex2.m1.2.xm">
                    <XMTok meaning="plus" role="ADDOP">+</XMTok>
                    <XMTok font="italic" role="UNKNOWN">x</XMTok>
                    <XMTok meaning="1" role="NUMBER">1</XMTok>
                  </XMApp>
                  <XMTok role="CLOSE" stretchy="false">)</XMTok>
                </XMWrap>
              </XMDual>
            </XMApp>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p3" fragid="p3">
    <equation xml:id="S0.Ex3" fragid="S0.Ex3">
      <Math mode="display" tex="\frac{x+1}{x^{2}+3x+2}" text="(x + 1) / (x ^ 2 + 3 * x + 2)" xml:id="S0.Ex3.m1" fragid="S0.Ex3.m1"><m:math alttext="\frac{x+1}{x^{2}+3x+2}" display="block"><m:semantics><m:apply><m:divide/><m:apply><m:plus/><m:ci>𝑥</m:ci><m:cn type="integer">1</m:cn></m:apply><m:apply><m:plus/><m:apply><m:csymbol cd="ambiguous">superscript</m:csymbol><m:ci>𝑥</m:ci><m:cn type="integer">2</m:cn></m:apply><m:apply><m:times/><m:cn type="integer">3</m:cn><m:ci>𝑥</m:ci></m:apply><m:cn type="integer">2</m:cn></m:apply></m:apply><m:annotation-xml encoding="application/x-latexml"><XMath><XMApp>
            <XMTok mathstyle="display" meaning="divide" role="FRACOP"/>
            <XMApp>
              <XMTok meaning="plus" role="ADDOP">+</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
            <XMApp>
              <XMTok meaning="plus" role="ADDOP">+</XMTok>
              <XMApp>
                <XMTok role="SUPERSCRIPTOP" scriptpos="post2"/>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
                <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
              </XMApp>
              <XMApp>
                <XMTok meaning="times" role="MULOP">⁢</XMTok>
                <XMTok meaning="3" role="NUMBER">3</XMTok>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
              </XMApp>
              <XMTok meaning="2" role="NUMBER">2</XMTok>
            </XMApp>
          </XMApp></XMath></m:annotation-xml></m:semantics></m:math></Math>
    </equation>
  </para>
  <para xml:id="p4" fragid="p4">
    <equation xml:id="S0.Ex4" fragid="S0.Ex4">
