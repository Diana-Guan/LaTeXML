<?xml version="1.0" encoding="UTF-8"?>
<?latexml searchpaths="/Users/guanshengmei/LaTeXML,/Users/guanshengmei/Documents/LaTeXML/test_input"?>
<?latexml class="article"?>
<?latexml package="amsmath,amssymb"?>
<?latexml RelaxNGSchema="LaTeXML"?>
<document xmlns="http://dlmf.nist.gov/LaTeXML">
  <resource src="LaTeXML.css" type="text/css"/>
  <resource src="ltx-article.css" type="text/css"/>
  <para xml:id="p1">
    <equation xml:id="S0.Ex1">
      <Math mode="display" tex="x+1" text="x + 1" xml:id="S0.Ex1.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
            <XMTok meaning="1" role="NUMBER">1</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p2">
    <equation xml:id="S0.Ex2">
      <Math mode="display" tex="x^{2}+1" text="x ^ 2 + 1" xml:id="S0.Ex2.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMApp>
              <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
            </XMApp>
            <XMTok meaning="1" role="NUMBER">1</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p3">
    <equation xml:id="S0.Ex3">
      <Math mode="display" tex="x^{3}-4x+7" text="(x ^ 3 - 4 * x) + 7" xml:id="S0.Ex3.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMApp>
              <XMTok meaning="minus" role="ADDOP">-</XMTok>
              <XMApp>
                <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
                <XMTok fontsize="70%" meaning="3" role="NUMBER">3</XMTok>
              </XMApp>
              <XMApp>
                <XMTok meaning="times" role="MULOP">⁢</XMTok>
                <XMTok meaning="4" role="NUMBER">4</XMTok>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
              </XMApp>
            </XMApp>
            <XMTok meaning="7" role="NUMBER">7</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p4">
    <equation xml:id="S0.Ex4">
      <Math mode="display" tex="a+b+c" text="a + b + c" xml:id="S0.Ex4.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="plus" role="ADDOP">+</XMTok>
            <XMTok font="italic" role="UNKNOWN">a</XMTok>
            <XMTok font="italic" role="UNKNOWN">b</XMTok>
            <XMTok font="italic" role="UNKNOWN">c</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p5">
    <equation xml:id="S0.Ex5">
      <Math mode="display" tex="xy" text="x * y" xml:id="S0.Ex5.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="times" role="MULOP">⁢</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
            <XMTok font="italic" role="UNKNOWN">y</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p6">
    <equation xml:id="S0.Ex6">
      <Math mode="display" tex="x(y+1)" text="x * (y + 1)" xml:id="S0.Ex6.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="times" role="MULOP">⁢</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
            <XMDual>
              <XMRef idref="S0.Ex6.m1.1"/>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMApp xml:id="S0.Ex6.m1.1">
                  <XMTok meaning="plus" role="ADDOP">+</XMTok>
                  <XMTok font="italic" role="UNKNOWN">y</XMTok>
                  <XMTok meaning="1" role="NUMBER">1</XMTok>
                </XMApp>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMDual>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p7">
    <equation xml:id="S0.Ex7">
      <Math mode="display" tex="\frac{x+1}{x-1}" text="(x + 1) / (x - 1)" xml:id="S0.Ex7.m1">
        <XMath>
          <XMApp>
            <XMTok mathstyle="display" meaning="divide" role="FRACOP"/>
            <XMApp>
              <XMTok meaning="plus" role="ADDOP">+</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
            <XMApp>
              <XMTok meaning="minus" role="ADDOP">-</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p8">
    <equation xml:id="S0.Ex8">
      <Math mode="display" tex="\sqrt{x+1}" text="square-root@(x + 1)" xml:id="S0.Ex8.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="square-root"/>
            <XMApp>
              <XMTok meaning="plus" role="ADDOP">+</XMTok>
              <XMTok font="italic" role="UNKNOWN">x</XMTok>
              <XMTok meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p9">
    <equation xml:id="S0.Ex9">
      <Math mode="display" tex="\sqrt[3]{x}" text="nth-root@(3, x)" xml:id="S0.Ex9.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="nth-root"/>
            <XMTok fontsize="70%" meaning="3" role="NUMBER">3</XMTok>
            <XMTok font="italic" role="UNKNOWN">x</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p10">
    <equation xml:id="S0.Ex10">
      <Math mode="display" tex="(x+1)^{2}" text="(x + 1) ^ 2" xml:id="S0.Ex10.m1">
        <XMath>
          <XMApp>
            <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
            <XMDual>
              <XMRef idref="S0.Ex10.m1.1"/>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMApp xml:id="S0.Ex10.m1.1">
                  <XMTok meaning="plus" role="ADDOP">+</XMTok>
                  <XMTok font="italic" role="UNKNOWN">x</XMTok>
                  <XMTok meaning="1" role="NUMBER">1</XMTok>
                </XMApp>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMDual>
            <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
  </para>
</document>
