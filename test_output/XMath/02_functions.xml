  </para>
  <para xml:id="p3">
    <equation xml:id="S0.Ex3">
      <Math mode="display" tex="\tan^{2}(x)" text="(tangent ^ 2)@(x)" xml:id="S0.Ex3.m1">
        <XMath>
          <XMDual>
            <XMApp>
              <XMRef idref="S0.Ex3.m1.2"/>
              <XMRef idref="S0.Ex3.m1.1"/>
            </XMApp>
            <XMApp>
              <XMApp xml:id="S0.Ex3.m1.2">
                <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                <XMTok meaning="tangent" role="TRIGFUNCTION">tan</XMTok>
                <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
              </XMApp>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMTok font="italic" role="UNKNOWN" xml:id="S0.Ex3.m1.1">x</XMTok>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMApp>
          </XMDual>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p4">
    <equation xml:id="S0.Ex4">
      <Math mode="display" tex="\ln(x)" text="natural-logarithm@(x)" xml:id="S0.Ex4.m1">
        <XMath>
          <XMDual>
            <XMApp>
              <XMRef idref="S0.Ex4.m1.1"/>
              <XMRef idref="S0.Ex4.m1.2"/>
            </XMApp>
            <XMApp>
              <XMTok meaning="natural-logarithm" role="OPFUNCTION" xml:id="S0.Ex4.m1.1">ln</XMTok>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMTok font="italic" role="UNKNOWN" xml:id="S0.Ex4.m1.2">x</XMTok>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
