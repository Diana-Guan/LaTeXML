  <para xml:id="p1">
    <equation xml:id="S0.Ex1">
      <Math mode="display" tex="\sin(x)" text="sine@(x)" xml:id="S0.Ex1.m1">
        <XMath>
          <XMDual>
            <XMApp>
              <XMRef idref="S0.Ex1.m1.1"/>
              <XMRef idref="S0.Ex1.m1.2"/>
            </XMApp>
            <XMApp>
              <XMTok meaning="sine" role="TRIGFUNCTION" xml:id="S0.Ex1.m1.1">sin</XMTok>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMTok font="italic" role="UNKNOWN" xml:id="S0.Ex1.m1.2">x</XMTok>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMApp>
          </XMDual>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p2">
    <equation xml:id="S0.Ex2">
      <Math mode="display" tex="\cos(x)" text="cosine@(x)" xml:id="S0.Ex2.m1">
