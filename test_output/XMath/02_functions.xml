  </para>
  <para xml:id="p5">
    <equation xml:id="S0.Ex5">
      <Math mode="display" tex="\ln(x^{2}+1)" text="natural-logarithm@(x ^ 2 + 1)" xml:id="S0.Ex5.m1">
        <XMath>
          <XMDual>
            <XMApp>
              <XMRef idref="S0.Ex5.m1.1"/>
              <XMRef idref="S0.Ex5.m1.2"/>
            </XMApp>
            <XMApp>
              <XMTok meaning="natural-logarithm" role="OPFUNCTION" xml:id="S0.Ex5.m1.1">ln</XMTok>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMApp xml:id="S0.Ex5.m1.2">
                  <XMTok meaning="plus" role="ADDOP">+</XMTok>
                  <XMApp>
                    <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                    <XMTok font="italic" role="UNKNOWN">x</XMTok>
                    <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                  </XMApp>
                  <XMTok meaning="1" role="NUMBER">1</XMTok>
                </XMApp>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMApp>
          </XMDual>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p6">
